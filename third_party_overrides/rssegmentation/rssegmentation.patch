 class CELoss(nn.Module):
     def __init__(self, ignore_index=255, reduction='mean'):
@@ -13,3 +14,47 @@ class CELoss(nn.Module):
     def forward(self, pred, target):
         loss = self.criterion(pred, target) 
         return loss
+
+
+class CEPlusDiceLoss(nn.Module):
+    """CE + multiclass Dice over non-ignored pixels."""
+
+    def __init__(
+        self,
+        ignore_index=255,
+        reduction='mean',
+        ce_weight=1.0,
+        dice_weight=1.0,
+        eps=1e-6,
+    ):
+        super(CEPlusDiceLoss, self).__init__()
+        self.ignore_index = ignore_index
+        self.ce_weight = float(ce_weight)
+        self.dice_weight = float(dice_weight)
+        self.eps = float(eps)
+        self.ce = nn.CrossEntropyLoss(ignore_index=ignore_index, reduction=reduction)
+
+    def _dice(self, pred, target):
+        num_classes = pred.shape[1]
+        probs = F.softmax(pred, dim=1)
+        valid = target != self.ignore_index
+        if valid.sum() == 0:
+            return pred.new_tensor(0.0)
+
+        target_safe = target.clone()
+        target_safe[~valid] = 0
+        onehot = F.one_hot(target_safe, num_classes=num_classes).permute(0, 3, 1, 2).float()
+
+        valid_f = valid.unsqueeze(1).float()
+        probs = probs * valid_f
+        onehot = onehot * valid_f
+
+        inter = (probs * onehot).sum(dim=(0, 2, 3))
+        denom = probs.sum(dim=(0, 2, 3)) + onehot.sum(dim=(0, 2, 3))
+        dice = (2.0 * inter + self.eps) / (denom + self.eps)
+        return 1.0 - dice.mean()
+
+    def forward(self, pred, target):
+        ce = self.ce(pred, target)
+        dice = self._dice(pred, target)
+        return self.ce_weight * ce + self.dice_weight * dice
